# GENERATED BY sparkyard — DO NOT EDIT. Edit models.yaml + `make render`.
general_settings:
  master_key: "os.environ/LITELLM_MASTER_KEY"
  ui_username: "os.environ/LITELLM_UI_USERNAME"
  ui_password: "os.environ/LITELLM_UI_PASSWORD"
  ui_access_mode: "admin_only"
  disable_master_key_return: true
  allow_model_creation: false

model_list:
{%- for m in models %}
{%- for served in m.served_names %}
  - model_name: {{ served }}
    litellm_params:
      model: openai/{{ m.name }}
      api_base: "http://llama-swap:8080/v1"
      api_key: "os.environ/LITELLM_MASTER_KEY"
{%- for key, value in m.litellm.items() %}
      {{ key }}: {{ value | tojson }}
{%- endfor %}
{%- endfor %}
{%- endfor %}

litellm_settings:
  drop_params: true
  set_verbose: false
  request_timeout: 900
  merge_reasoning_content_in_choices: true
  stream: true
  health_check_interval: 0
  num_retries: 0
  fallbacks: []
