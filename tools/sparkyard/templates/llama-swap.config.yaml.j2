# GENERATED BY sparkyard — DO NOT EDIT. Edit models.yaml + `make render`.
host: "0.0.0.0"
port: 8080
timeout: 3600
readyTimeout: 3600
healthCheckTimeout: 900
logLevel: "info"
metricsMaxInMemory: 1000

macros:
  host: "0.0.0.0"
  tensor_parallel: "1"

models:
{% for m in models %}
  {{ m.name }}:
    ttl: {{ m.ttl }}
    readyTimeout: {{ m.ready_timeout }}
    checkEndpoint: "{{ m.check_endpoint }}"
{%- if m.engine == "vllm" %}
    cmd: >
      env
      MODEL_PATH={{ m.model_path }}
      MODEL_HOST_PATH={{ m.model_host_path }}
      CONTAINER_NAME={{ m.container }}-${PORT}
      IMAGE={{ m.image }}
      PORT=${PORT} HOST=${host}
      MAX_MODEL_LEN={{ m.max_model_len }} MAX_NUM_SEQS={{ m.max_num_seqs }} KV_DTYPE_BYTES={{ m.kv_dtype_bytes }}
{%- if m.gmem_override is not none %}
      GMEM_OVERRIDE={{ m.gmem_override }}
{%- endif %}
      GMEM_MIN={{ m.gmem_min }} GMEM_MAX={{ m.gmem_max }} SAFETY_GIB={{ m.safety_gib }}
{%- if m.extra_docker_args %}
      EXTRA_DOCKER_ARGS='{{ m.extra_docker_args }}'
{%- endif %}
{%- if m.pre_launch_cmd %}
      PRE_LAUNCH_CMD='{{ m.pre_launch_cmd }}'
{%- endif %}
      python3 /app/scripts/launch.py
      --served-model-name {{ m.served_names | join(' ') }}
{%- if m.chat_template %}
      --chat-template {{ m.chat_template_path }}
{%- endif %}
{%- for flag in m.vllm_flags %}
      {{ flag }}
{%- endfor %}
    cmdStop: "docker stop {{ m.container }}-${PORT}"
{%- elif m.engine == "llamacpp" %}
    cmd: >
      docker run --rm --name {{ m.container }}-${PORT}
      --runtime nvidia --gpus all --ipc host --network container:llama-swap
      --ulimit memlock=-1 --ulimit stack=67108864
      --security-opt seccomp=unconfined
{%- if m.unified_memory %}
      -e GGML_CUDA_ENABLE_UNIFIED_MEMORY=1
{%- endif %}
      -v {{ m.mount }}
      {{ m.image }}
      -m {{ m.gguf }}
      --alias {{ m.name }}
      --port ${PORT} --host ${host}
      --ctx-size {{ m.ctx_size }} --n-gpu-layers {{ m.n_gpu_layers }} --parallel {{ m.parallel }}{% if m.no_mmap %} --no-mmap{% endif %}
{%- if m.chat_template %}
      --jinja
      --chat-template-file {{ m.chat_template_path }}
{%- endif %}
{%- for flag in m.llamacpp_flags %}
      {{ flag }}
{%- endfor %}
    cmdStop: "docker stop {{ m.container }}-${PORT}"
{%- endif %}
{% endfor %}
