# Sparkyard secrets — copy to `secrets.env`, fill in, then `chmod 600 secrets.env`.
# secrets.env is gitignored and is the ONLY place secret VALUES live.
# `make secrets` will scaffold this file and auto-generate the random ones.

# Auto-generatable (make secrets fills these if blank):
LITELLM_MASTER_KEY=
LITELLM_UI_PASSWORD=
POSTGRES_PASSWORD=

# User-supplied (cannot be generated — paste your own):
# HF_TOKEN — a Hugging Face access token. Only needed to download GATED or
#   PRIVATE models (public models, including the examples, download without it).
#   Create a READ token at https://huggingface.co/settings/tokens. Used only by
#   `make download` / `make add-model` — never sent to a running container.
HF_TOKEN=

# Non-secret but kept here for convenience (used by LiteLLM + Postgres):
LITELLM_UI_USERNAME=admin
POSTGRES_DB=litellm
POSTGRES_USER=litellm_admin

# Derived / auto-filled by `make secrets` (do not edit by hand):
WEBUI_SECRET_KEY=
DATABASE_URL=
OPENAI_API_KEY=
